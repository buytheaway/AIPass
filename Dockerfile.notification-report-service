FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/notification-report-service ./cmd/notification-report-service

FROM alpine:3.20
WORKDIR /app
COPY --from=build /out/notification-report-service /app/notification-report-service
EXPOSE 8082
CMD ["/app/notification-report-service"]

